[project]
name = "document-intelligent-system"
version = "0.1.0"
description = "Add your description here"
readme = "README.md"
requires-python = ">=3.12"
dependencies = [
    "accelerate>=1.14.0",
    "awswrangler>=3.17.0",
    "azureml-core>=1.61.0.post4",
    "captum>=0.9.0",
    "colossalai>=0.3.6",
    "confluent-kafka>=2.14.2",
    "dask[complete]>=2026.6.0",
    "deepspeed>=0.19.2",
    "delta-spark>=4.3.0",
    "dlt>=1.28.1",
    "feast>=0.64.0",
    "feature-engine>=1.9.4",
    "featurebyte>=3.4.0",
    "google-cloud-aiplatform>=1.158.0",
    "joblib>=1.5.3",
    "lightning>=2.6.5",
    "mlflow>=3.14.0",
    "nni>=3.0",
    "numpy>=2.3.5",
    "optuna>=4.9.0",
    "pandas>=2.3.3",
    "pyarrow>=24.0.0",
    "pyspark>=4.1.1",
    "ray[default]>=2.55.1",
    "redis>=8.0.1",
    "scikit-learn>=1.9.0",
    "shap>=0.52.0",
    "statsmodels>=0.14.6",
    "structlog>=26.1.0",
    "torch>=2.12.1",
    "torchaudio>=2.11.0",
    "torchvision>=0.27.1",
    "transformers>=5.12.1",
    "wandb>=0.28.0",
]

[dependency-groups]
dev = [
    "pytest>=9.1.1",
]
